# Atlas Core — variables de entorno
# Copia este archivo a .env y rellena los valores. .env esta en .gitignore.

# -- Gate C: Hermes (REST + HMAC sobre Tailscale) -----------------------------
HERMES_BASE_URL=http://<tailscale-ip-vps>:8443
HERMES_API_KEY=<emitido-por-install_hermes_vps.sh>

# -- Gate C: Telegram bot -----------------------------------------------------
# TELEGRAM_BOT_TOKEN=<token-de-BotFather>
# TELEGRAM_CHAT_ID=<chat-id-autorizado>

# -- Gate D: InferenceHub (LiteLLM, ADR-016) ----------------------------------
# Modo de ejecucion: "auto" (default), "live" o "stub".
# - auto: live cuando hay key + litellm + no en pytest; stub en otro caso.
# - live: fuerza llamada real (falla si no hay key).
# - stub: nunca llama al exterior.
# ATLAS_INFERENCE_MODE=auto

# Al menos una de estas keys debe estar presente para modo live:
GROQ_API_KEY=<gsk_...>
OPENROUTER_API_KEY=<sk-or-v1-...>
# TOGETHERAI_API_KEY=<...>
# GEMINI_API_KEY=<...>

# -- Gate C: Tailscale --------------------------------------------------------
# TAILSCALE_AUTH_KEY=<tskey-auth-...>  # solo en setup; no se lee en runtime
