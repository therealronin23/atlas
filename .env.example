# Atlas Core — variables de entorno
# Copia este archivo a .env y rellena los valores. .env esta en .gitignore.

# -- Hermes-Agent oficial + twin firmado sobre red privada/Tailscale ----------
# El wrapper genera HERMES_API_KEY si se deja vacía y persiste .env como 0600.
HERMES_API_KEY=
ATLAS_DASHBOARD_URL=http://<tailscale-ip-atlas>:7331
TELEGRAM_BOT_TOKEN=<token-de-BotFather>
TELEGRAM_ALLOWED_USERS=<telegram-user-id-numerico>
HERMES_MODEL_PROVIDER=custom:groq
HERMES_MODEL=<model-id-del-proveedor>

# Canal Atlas -> Hermes por kanban. El destino incluye usuario SSH y solo puede
# ser privado/Tailscale. Para desplegar: VPS_HOST=<host-sin-usuario> \
# scripts/deploy_hermes_vps_oneshot.sh
# HERMES_KANBAN_TRANSPORT=ssh
# HERMES_SSH_HOST=root@<tailscale-ip-vps>

# Compatibilidad heredada con HermesRestAdapter; no corresponde al
# Hermes-Agent nativo ni debe usarse como prueba de que este está vivo.
# HERMES_BASE_URL=http://<private-legacy-rest-origin>:8443

# -- Bot Telegram propio de Atlas (distinto del bot gestionado por Hermes) ----
# TELEGRAM_CHAT_ID=<chat-id-autorizado>

# -- Gate D: InferenceHub (LiteLLM, ADR-016) ----------------------------------
# Modo de ejecucion: "auto" (default), "live" o "stub".
# - auto: live cuando hay key + litellm + no en pytest; stub en otro caso.
# - live: fuerza llamada real (falla si no hay key).
# - stub: nunca llama al exterior.
# ATLAS_INFERENCE_MODE=auto

# Al menos una de estas keys debe estar presente para modo live:
GROQ_API_KEY=<gsk_...>
OPENROUTER_API_KEY=<sk-or-v1-...>
# TOGETHERAI_API_KEY=<...>
# GEMINI_API_KEY=<...>

# -- Gate D/D4: Embeddings (LiteLLM) -----------------------------------------
# Modo del LiteLLMEmbedder: auto/live/stub (default auto).
# ATLAS_EMBEDDING_MODE=auto
# Para live se necesita una key con endpoint de embeddings:
# OPENAI_API_KEY=<sk-...>           # text-embedding-3-small (1536 dim)
# (GEMINI_API_KEY tambien sirve via gemini/text-embedding-004, 768 dim)

# -- Gate C: Tailscale --------------------------------------------------------
# TAILSCALE_AUTH_KEY=<tskey-auth-...>  # solo en setup; no se lee en runtime
