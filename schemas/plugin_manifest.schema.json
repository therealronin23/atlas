{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/plugin_manifest.schema.json",
  "title": "Atlas Declarative Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plugin_id",
    "display_name",
    "version",
    "source",
    "activation",
    "permissions",
    "contributions"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$",
      "minLength": 3,
      "maxLength": 64
    },
    "display_name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": { "type": "string", "minLength": 1, "maxLength": 120 },
    "source": { "$ref": "#/$defs/plugin_source" },
    "activation": { "const": "declarative" },
    "permissions": {
      "type": "array",
      "maxItems": 0,
      "items": { "enum": ["read_context", "write_workspace", "network"] }
    },
    "contributions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/plugin_contribution" }
    }
  },
  "$defs": {
    "plugin_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "revision", "license"],
      "properties": {
        "origin": { "type": "string", "minLength": 1, "maxLength": 512 },
        "revision": { "type": "string", "minLength": 1, "maxLength": 512 },
        "license": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "plugin_contribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contribution_id", "kind", "path"],
      "properties": {
        "contribution_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$",
          "minLength": 3,
          "maxLength": 64
        },
        "kind": { "enum": ["skill", "prompt", "rule", "command"] },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+\\.md$"
        }
      }
    }
  }
}
