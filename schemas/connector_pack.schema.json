{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/connector_pack.schema.json",
  "title": "AtlasConnectorPack",
  "description": "Pack de conexiones por sector: qué recetas ofrecer juntas y en qué orden montarlas para un mundo operativo (gestoría, restauración...).",
  "type": "object",
  "required": [
    "pack_id",
    "sector_id",
    "display_name",
    "connectors",
    "setup_order",
    "demo"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+_pack$"
    },
    "sector_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "connectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "connector_ids de recetas existentes"
    },
    "setup_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "optional_connectors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rationale": {
      "type": [
        "string",
        "null"
      ],
      "description": "por qué este pack sirve a este sector"
    },
    "demo": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
