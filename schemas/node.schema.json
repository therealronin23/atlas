{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/node.schema.json",
  "title": "AtlasGraphNode",
  "type": "object",
  "required": [
    "id",
    "type",
    "label",
    "state",
    "confidence",
    "activity",
    "risk",
    "source",
    "actions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^node_[A-Za-z0-9_-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "user",
        "memory",
        "tool",
        "process",
        "artifact",
        "runtime",
        "project",
        "account",
        "conversation",
        "intent",
        "adapter",
        "gate",
        "model",
        "document",
        "decision",
        "pattern",
        "error",
        "connector",
        "agent",
        "source",
        "workspace"
      ]
    },
    "label": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "idle",
        "active",
        "running",
        "waiting_user",
        "blocked",
        "completed",
        "failed",
        "archived"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "activity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "source": {
      "type": "string"
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
