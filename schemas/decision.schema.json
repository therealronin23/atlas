{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/decision.schema.json",
  "title": "AtlasDecision",
  "description": "Decision de primera clase (ADR, veredicto de gate, eleccion de plan).",
  "type": "object",
  "required": [
    "decision_id",
    "title",
    "status",
    "decided_at",
    "rationale"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^dec_[A-Za-z0-9_-]+$"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "rejected",
        "superseded"
      ]
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "rationale": {
      "type": "string"
    },
    "adr_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
