{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/artifact.schema.json",
  "title": "AtlasArtifact",
  "description": "Artefacto producido por un proceso (fichero, informe, diff, PDF...).",
  "type": "object",
  "required": [
    "artifact_id",
    "kind",
    "label",
    "created_at",
    "produced_by"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^art_[A-Za-z0-9_-]+$"
    },
    "kind": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "path_or_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "produced_by": {
      "type": "string",
      "description": "process_id o tool que lo creo"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "simulated": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
