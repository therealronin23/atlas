{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/permission.schema.json",
  "title": "AtlasPermissionEvaluation",
  "description": "Resultado de evaluar una accion contra las politicas. La evaluacion la hace governance/ existente; esto es el contrato de representacion.",
  "type": "object",
  "required": [
    "action",
    "resource",
    "decision",
    "risk",
    "evaluated_at",
    "reason"
  ],
  "properties": {
    "action": {
      "type": "string"
    },
    "resource": {
      "type": "string"
    },
    "actor": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "require_approval"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "reason": {
      "type": "string"
    },
    "policy_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "gate_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "reversible": {
      "type": [
        "boolean",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
