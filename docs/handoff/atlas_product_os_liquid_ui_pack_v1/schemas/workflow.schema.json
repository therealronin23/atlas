    "workflow_id": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "objective_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array"
    },
    "edges": {
      "type": "array"
    },
    "capabilities_required": {
      "type": "array",
