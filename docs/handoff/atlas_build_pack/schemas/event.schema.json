{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/event.schema.json",
  "title": "AtlasEvent",
  "type": "object",
  "required": [
    "id",
    "type",
    "timestamp",
    "schema_version",
    "source",
    "summary",
    "status",
    "risk",
    "visible",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9_-]+$"
    },
    "type": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "schema_version": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "workspace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "intent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "process_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "idle",
        "queued",
        "running",
        "waiting_user",
        "blocked",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "visible": {
      "type": "boolean"
    },
    "payload": {
      "type": "object"
    },
    "audit": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "merkle_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "previous_hash": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}