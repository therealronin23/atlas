{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/edge.schema.json",
  "title": "AtlasGraphEdge",
  "type": "object",
  "required": [
    "id",
    "source",
    "target",
    "relation",
    "weight",
    "confidence",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^edge_[A-Za-z0-9_-]+$"
    },
    "source": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "relation": {
      "type": "string"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}